# .env.example
#
# Copy this file to .env and fill in the values for manual (non-Umbrel) usage.
# On UmbrelOS, these variables are injected automatically by Umbrel — you do
# NOT need to set them manually.
#
# Usage:
#   cp .env.example .env
#   nano .env
#   docker compose --env-file .env up -d

# ── Umbrel Bitcoin node (burnchain backend) ─────────────────────────────────

# Internal Docker IP of the Umbrel Bitcoin container.
# On UmbrelOS this is set automatically as APP_BITCOIN_NODE_IP.
APP_BITCOIN_NODE_IP=10.21.21.8

# Bitcoin Core RPC port (default: 8332).
APP_BITCOIN_RPC_PORT=8332

# Bitcoin Core RPC credentials.
# On UmbrelOS these are set automatically.
APP_BITCOIN_RPC_USER=umbrel
APP_BITCOIN_RPC_PASS=changeme

# ── Stacks Node container IPs ────────────────────────────────────────────────
# Assign static IPs on the umbrel_main_network (10.21.0.0/16).
# Choose IPs that do not conflict with other apps on your Umbrel device.
# Umbrel sets these automatically when installed via the app store.

APP_STACKS_NODE_INIT_IP=10.21.21.50
APP_STACKS_NODE_IP=10.21.21.51

# ── App data directory ───────────────────────────────────────────────────────
# On UmbrelOS this is set to ~/umbrel/app-data/stacks-node.
# For manual usage outside Umbrel, set this to a local path.
APP_DATA_DIR=./data
